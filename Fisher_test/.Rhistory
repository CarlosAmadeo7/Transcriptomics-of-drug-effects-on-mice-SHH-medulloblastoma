load("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/Pritika_palbociclib_gherson/deconvolution/seuObject_slim_nodoub.RData")
## Loading Single cell Object
#load("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/")
DimPlot(seuObject_slim_nodoub)
## Loading Single cell Object
#load("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/")
DimPlot(seuObject_slim_nodoub, group.by = "celltype")
## Loading Single cell Object
#load("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/")
DimPlot(seuObject_slim_nodoub, group.by = "celltype1")
## Loading Single cell Object
#load("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/")
DimPlot(seuObject_slim_nodoub, group.by = "celltype")
# Calculate the DEGs and then export it
DEGs_Object <- Reduce("rbind",lapply(unique(seuObject_slim_nodoub$celltype), function(x) {
Markers <- FindMarkers(seuObject_slim_nodoub, ident.1 = x, ident.2 = NULL, only.pos = TRUE, min.pct = 0.1, logfc.threshold = 0.5, pseudocount.use = 0.1)
Markers <- Markers[which(Markers$p_val_adj < 0.05),]
Markers$gene <- rownames(Markers)
Markers$cluster <- rep(paste("Cluster", x),nrow(Markers))
return(Markers)
}))
View(DEGs_Object)
View(DEGs_Object)
#Markers$cluster <- rep(paste("Cluster", x),nrow(Markers))
Markers$cluster<- rep(paste(x),nrow(Markers))
# Calculate the DEGs and then export it
DEGs_Object <- Reduce("rbind",lapply(unique(seuObject_slim_nodoub$celltype), function(x) {
Markers <- FindMarkers(seuObject_slim_nodoub, ident.1 = x, ident.2 = NULL, only.pos = TRUE, min.pct = 0.1, logfc.threshold = 0.5, pseudocount.use = 0.1)
Markers <- Markers[which(Markers$p_val_adj < 0.05),]
Markers$gene <- rownames(Markers)
#Markers$cluster <- rep(paste("Cluster", x),nrow(Markers))
Markers$cluster<- rep(paste(x),nrow(Markers))
return(Markers)
}))
View(DEGs_Object)
## Loading the DEG objects from Combo, Ribo , BMS vs DMSO
Combo<-read_xlsx("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/edgeR_new_exploration/deg/Combo_DMSO/CTX_DGE_shrink.xlsx")
View(Combo)
BMS<-read_xlsx("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/edgeR_new_exploration/deg/BMS_DMSO/CTX_DGE_shrink.xlsx")
Ribo<- read_xlsx("C:/Users/amade/Documents/Pritika's_project_BMS_Ribo_Combo/edgeR_new_exploration/deg/Ribo_DMSO/CTX_DGE_shrink.xlsx")
View(Ribo)
View(DEGs_Object)
View(Combo)
df<- Combo %>%
mutate(LOG=-log10(FDR), ABS=abs(logFC))%>%
mutate(Threshold = if_else(FDR<0.05 & ABS>0.3, "TRUE", "FALSE"))%>%
mutate(Direction = case_when(logFC>0.3 & FDR<0.05 ~ "UpReg", logFC< -0.3 & FDR<0.05 ~ "DownReg"))
View(Combo)
df<- Combo %>%
mutate(LOG=-log10(padj), ABS=abs(log2FoldChange))%>%
mutate(Threshold = if_else(padj<0.05 & ABS>0.3, "TRUE", "FALSE"))%>%
mutate(Direction = case_when(log2FoldChange>0.3 & padj<0.05 ~ "UpReg", log2FoldChange< -0.3 & padj<0.05 ~ "DownReg"))
View(df)
View(df)
df<- Combo %>%
mutate(LOG=-log10(padj), ABS=abs(log2FoldChange))%>%
mutate(Threshold = if_else(padj<0.05 & ABS>0.3, "TRUE", "FALSE"))%>%
mutate(Direction = case_when(log2FoldChange>0.3 & padj<0.05 ~ "UpReg", log2FoldChange< -0.3 & padj<0.05 ~ "DownReg")) %>%
dplyr::select(Gene, Direction)
View(df)
### Creating a dataframe with All Direction
all <- data.frame(Gene=df$Gene,Direction="All")
View(all)
#### Creating a single data frame and overlap them, and saving them in a text file
deg = rbind(df, all)
View(deg)
#### Creating a single data frame and overlap them, and saving them in a text file
deg = rbind(df, all)
write.table(deg, "deg.Combo.DMSO.txt", sep="\t", quote = F)
## BMS vs DMSO
df <- BMS %>%
mutate(LOG=-log10(padj), ABS=abs(log2FoldChange))%>%
mutate(Threshold = if_else(padj<0.05 & ABS>0.3, "TRUE", "FALSE"))%>%
mutate(Direction = case_when(log2FoldChange>0.3 & padj<0.05 ~ "UpReg", log2FoldChange< -0.3 & padj<0.05 ~ "DownReg")) %>%
dplyr::select(Gene, Direction)
all <- data.frame(Gene=df$Gene,Direction="All")
deg = rbind(df, all)
View(deg)
write.table(deg, "deg.BMS.DMSO.txt", sep="\t", quote = F)
## Ribo vs DMSO
df <- Ribo %>%
mutate(LOG=-log10(padj), ABS=abs(log2FoldChange))%>%
mutate(Threshold = if_else(padj<0.05 & ABS>0.3, "TRUE", "FALSE"))%>%
mutate(Direction = case_when(log2FoldChange>0.3 & padj<0.05 ~ "UpReg", log2FoldChange< -0.3 & padj<0.05 ~ "DownReg")) %>%
dplyr::select(Gene, Direction)
all <- data.frame(Gene=df$Gene,Direction="All")
deg = rbind(df, all)
write.table(deg, "deg.Ribo.DMSO.txt", sep="\t", quote = F)
gene.clusters<- DEGs_Object %>% dplyr::select(gene, cluster)
View(gene.clusters)
View(gene.clusters)
colnames(gene.clusters)= c("Gene","Clusters")
View(deg)
###### CReate a tmp for modification purposes
#tmp<-df13.clusters
#tmp$cluster<-paste("Cluster",tmp$cluster, "")
### Ensuring clusters are order numerically
GeneSets <- split(gene.clusters, gene.clusters$Clusters)
View(GeneSets)
save(GeneSets, file= "utils/geneset/GeneSets_Palbociclib_DMSO.RData")
View(Combo)
View(gene.clusters)
View(deg)
